# =============================================================
#  ROOT .gitignore — Covers both backend and frontend
# =============================================================

# ── SECRET FILES (NEVER PUSH THESE) ─────────────────────────
.env
.env.local
.env.production
.env.*.local
*.env

# ── Node Modules ─────────────────────────────────────────────
node_modules/
backend/node_modules/
frontend/node_modules/

# ── Build Outputs ─────────────────────────────────────────────
frontend/dist/
frontend/build/
backend/dist/

# ── Logs ──────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS Files ──────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE / Editor ──────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
