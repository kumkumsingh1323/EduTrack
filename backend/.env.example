# ─────────────────────────────────────────────────────────────
#  STEP 1: Replace the values below with your own credentials
#  Copy this file → rename to .env → fill in your values
# ─────────────────────────────────────────────────────────────

# MongoDB Atlas connection string
# Get it from: Atlas → Database → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://<DB_USER>:<DB_PASSWORD>@<CLUSTER>.mongodb.net/<DB_NAME>?retryWrites=true&w=majority

# Server port (default: 5000)
PORT=5000

# Gemini AI API Key (optional — for AI chat features)
# Get it from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
